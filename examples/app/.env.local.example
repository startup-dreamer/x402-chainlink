# =============================================================================
# Chainlink x402 Starter Kit — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# CLIENT SIDE (exposed to browser — use testnet keys only)
# -----------------------------------------------------------------------------

# Private key of the wallet that pays for API requests (Base Sepolia testnet)
# This wallet needs USDC on Base Sepolia (get from faucet)
NEXT_PUBLIC_SENDER_PRIVATE_KEY=0x...your_testnet_private_key_here

# Network to use (Base Sepolia testnet)
NEXT_PUBLIC_NETWORK=eip155:84532

# -----------------------------------------------------------------------------
# SERVER SIDE (never exposed to browser)
# -----------------------------------------------------------------------------

# Address that receives USDC payments from API requests
RECEIVER_ADDRESS=0x...your_receiver_wallet_address

# X402Facilitator contract address on Base Sepolia
# Deploy contracts/src/X402Facilitator.sol from x402-chainlink, then paste address here
# Required only when CRE_BROADCAST=true
FACILITATOR_ADDRESS=0x0000000000000000000000000000000000000000

# Path to the x402-workflow directory (for CRE simulation)
# Default points to the sibling x402-chainlink repo
WORKFLOW_PATH=../x402-chainlink/x402-workflow

# Target settings name for CRE simulation (matches workflow.yaml)
CRE_TARGET=staging-settings

# Set to "true" to broadcast real transactions to Base Sepolia
# Requires: cre CLI installed, FACILITATOR_ADDRESS set, funded settler wallet
CRE_BROADCAST=false
